# Repo-root environment variables (migration scripts)
#
# Next.js reads apps/webapp/.env.local — use apps/webapp/.env.example as the
# full template. Copy the Supabase sections here for root scripts:
#
#   cp apps/webapp/.env.example .env.local
#   # or copy only the Supabase blocks into an existing root .env.local
#
# Scripts that load this file: apply-migrations, list-tables, migration:*

# --- Current (old) Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=

# --- Migration target (new paid Supabase, Plan 10) ---
MIGRATION_NEXT_PUBLIC_SUPABASE_URL=
MIGRATION_NEXT_PUBLIC_SUPABASE_ANON_KEY=
MIGRATION_SUPABASE_SERVICE_ROLE_KEY=
MIGRATION_SUPABASE_ACCESS_TOKEN=
