# Midwest EA — environment variables
#
# Local dev (Next.js):
#   cp apps/webapp/.env.example apps/webapp/.env.local
#
# Migration scripts (repo root — apply-migrations, list-tables, migration:*):
#   Copy the Supabase blocks below to .env.local at the REPO ROOT as well.
#
# Never commit .env or .env.local (secrets stay local / in Vercel).

# ---------------------------------------------------------------------------
# Supabase — current (old shared project; live Webflow + staging today)
# Dashboard: Project Settings → API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional server-only aliases (scripts accept these as fallbacks)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Management API token — scripts only (https://supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Supabase — migration target (new paid project, Plan 10)
#
# Fill from the NEW project dashboard. Keep unprefixed vars on the OLD project
# until the end of Plan 10, when Vercel Preview is switched to the new DB.
# Production stays on old DB until Plan 13 cutover.
#
# Migration scripts read MIGRATION_* for the target; app + unprefixed vars = source.
# ---------------------------------------------------------------------------
MIGRATION_NEXT_PUBLIC_SUPABASE_URL=
MIGRATION_NEXT_PUBLIC_SUPABASE_ANON_KEY=
MIGRATION_SUPABASE_SERVICE_ROLE_KEY=

# Optional aliases for migration scripts
MIGRATION_SUPABASE_URL=
MIGRATION_SUPABASE_ANON_KEY=

# Management API token for the NEW project (schema apply, table listing)
MIGRATION_SUPABASE_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Stripe (same keys during DB migration — webhook URL unchanged on staging)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Email (Plan 12 — optional until Resend is wired)
# ---------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=noreply@midwestea.com

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# QuickBooks (optional — admin invoice reconcile)
# See docs/quickbooks-oauth-setup.md
# ---------------------------------------------------------------------------
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_COMPANY_ID=
QUICKBOOKS_REALM_ID=
QUICKBOOKS_ACCESS_TOKEN=
QUICKBOOKS_REFRESH_TOKEN=
QUICKBOOKS_USE_SANDBOX=true
