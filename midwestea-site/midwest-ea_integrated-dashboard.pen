                        },
                        {
                          "type": "frame",
                          "id": "BFaTu",
                          "name": "Editor Content",
                          "width": "fill_container",
                          "height": "fill_container",
                          "layout": "vertical",
                          "gap": 14,
                          "padding": 20,
                          "children": [
                            {
                              "type": "text",
                              "id": "GSuvP",
                              "name": "Paragraph 1",
                              "fill": "#18181B",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "When the Chang family moved to Maple Leaf in 2019, they brought more than furniture and moving boxes — they brought a vision for what a neighborhood could feel like when people actually know each other.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 15,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "i00PZk",
                              "name": "Paragraph 2",
                              "fill": "#18181B",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Within their first month, Mei started hosting monthly potlucks on their front porch. What began as a handful of neighbors sharing casseroles has grown into one of the most anticipated gatherings on the block.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 15,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "G84tat",
                              "name": "Paragraph 3",
                              "fill": "#18181B",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "\"We didn't move here to live next to strangers,\" Mei says. \"We moved here to build something together.\"",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 15,
                              "fontWeight": "normal",
                              "fontStyle": "italic"
                            },
                            {
                              "type": "text",
                              "id": "EH2rV",
                              "name": "Paragraph 4",
                              "fill": "#18181B",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Today, the Changs help coordinate the neighborhood garden tour, mentor new families, and keep the community bulletin board stocked with local events. Their story is a reminder that belonging starts with a simple invitation.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 15,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
